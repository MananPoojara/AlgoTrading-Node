# SmartAPI Test Configuration
# Copy this file to .env and fill in your actual credentials

# Your Angel One API Key from SmartAPI portal
ANGEL_ONE_API_KEY=your_api_key_here

# Your Angel One Client Code (Login ID)
ANGEL_ONE_CLIENT_CODE=your_client_code_here

# Your Angel One Password
ANGEL_ONE_PASSWORD=your_password_here

# TOTP Secret from SmartAPI portal (NOT the PIN - you need the base32 secret)
# This is NOT the 6-digit OTP - it's the secret used to generate OTP
ANGEL_ONE_TOTP_SECRET="your_totp_secret_here"

# Paper Trading (use for testing)
PAPER_MODE=true

# API Base URL (usually don't change this)
ANGEL_ONE_API_URL=https://apiconnect.angelone.in

# WebSocket URL
ANGEL_ONE_WS_URL=wss://smartapisocket.angelone.in/smart-stream

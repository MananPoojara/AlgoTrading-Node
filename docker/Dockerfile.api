# API Server Dockerfile
FROM node:18-alpine

WORKDIR /app

COPY package*.json ./
COPY node_modules/ ./node_modules/
COPY src/ ./src/
COPY config/ ./config/

RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001 -G nodejs && \
    mkdir -p /app/logs && \
    chown nodejs:nodejs /app/logs
USER nodejs

EXPOSE 3001

CMD ["node", "src/api/server.js"]

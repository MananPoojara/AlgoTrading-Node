# Database Configuration
POSTGRES_DB=algo_trading
POSTGRES_USER=algo
POSTGRES_PASSWORD=algo123
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# Application Configuration
NODE_ENV=development
PORT=3001

# JWT Configuration
JWT_SECRET=change-this-to-a-secure-random-string-in-production
JWT_EXPIRY=8h

# Encryption Key for API credentials
ENCRYPTION_KEY=change-this-to-a-secure-32-char-key

# Angel One API (Paper Trading)
ANGEL_ONE_API_KEY=
ANGEL_ONE_API_SECRET=
ANGEL_ONE_WS_URL=
ANGEL_ONE_CLIENT_CODE=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=your_totp_secret
ANGEL_ONE_HISTORICAL_ENABLED=true
ANGEL_ONE_HISTORICAL_API_KEY=
ANGEL_ONE_HISTORICAL_CLIENT_CODE=
ANGEL_ONE_HISTORICAL_PASSWORD=
ANGEL_ONE_HISTORICAL_TOTP_SECRET=
ANGEL_ONE_HISTORICAL_LOOKBACK_DAYS=730
ANGEL_ONE_HISTORICAL_MAX_DAYS_PER_REQUEST=365
ANGEL_ONE_HISTORICAL_MAX_REQUESTS_PER_SECOND=3
ANGEL_ONE_HISTORICAL_MAX_REQUESTS_PER_MINUTE=180
ANGEL_ONE_HISTORICAL_RATE_LIMIT_RETRY_DELAY_MS=61000
ANGEL_ONE_HISTORICAL_MAX_RETRIES=2
# Redirect URL for SmartAPI OAuth (frontend callback)
ANGEL_ONE_REDIRECT_URL=
# Paper trading credentials
ANGEL_ONE_PAPER_API_KEY=
ANGEL_ONE_PAPER_API_SECRET=

# XTS_API_KEY=
XTS_API_SECRET=
XTS_INTERACTIVE_URL=https://xtsapi.co.in
XTS_MARKET_DATA_URL=https://mdxapi.co.in

# Symphony API (Phase 2)
SYMPHONY_API_KEY=
SYMPHONY_API_SECRET=

# Paper Trading Mode (true = simulated, false = live)
PAPER_MODE=true

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs
API_REQUEST_LOG_LEVEL=debug
WS_CLIENT_LOG_LEVEL=debug
MARKET_DATA_REFRESH_LOG_LEVEL=debug

# Risk Limits (Defaults)
DEFAULT_MAX_DAILY_LOSS=50000
DEFAULT_MAX_OPEN_POSITIONS=10
DEFAULT_MAX_LOTS_PER_TRADE=5
DEFAULT_SIGNAL_COOLDOWN_SECONDS=5

# Market Hours (IST)
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
AUTO_SQUARE_OFF_TIME=15:15
MARKET_SCHEDULER_ENABLED=true
MARKET_SCHEDULER_POLL_MS=30000
MARKET_FEED_START_TIME=09:00
STRATEGY_START_TIME=09:15
STRATEGY_STOP_TIME=15:45
MARKET_FEED_STOP_TIME=16:10
MARKET_TICK_ARCHIVE_ROOT=/app/data/market-archive
MARKET_TICK_ARCHIVE_BATCH_SIZE=50000

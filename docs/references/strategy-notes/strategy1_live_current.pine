//@version=5
strategy(
    "Strategy1 Live Current",
    overlay=true,
    pyramiding=0,
    process_orders_on_close=true,
    initial_capital=100000,
    default_qty_type=strategy.fixed,
    default_qty_value=1
)

maxRed = input.int(3, "Consecutive Red Candles", minval=1)
atrPeriod = input.int(5, "ATR Period", minval=1)
atrFactor = input.float(2.0, "ATR Factor", minval=0.1, step=0.1)
showSignals = input.bool(true, "Show Buy/Sell Markers")

isRed = open > close
redCount = isRed ? nz(redCount[1]) + 1 : 0

prevClose = close[1]
highLow = high - low
highPrevClose = na(prevClose) ? 0.0 : math.abs(high - prevClose)
lowPrevClose = na(prevClose) ? 0.0 : math.abs(low - prevClose)
trueRange = math.max(highLow, math.max(highPrevClose, lowPrevClose))

customAtr = bar_index >= atrPeriod - 1 ? ta.sma(trueRange, atrPeriod) : na
trailingBase = na(customAtr) ? na : ((high + low) / 2.0) - (customAtr * atrFactor)

var float trailingStop = na
var bool inPosition = false
var int entryBarIndex = na

buySignal = false
sellSignal = false

if barstate.isconfirmed
    if not inPosition
        if redCount >= maxRed
            buySignal := true
            inPosition := true
            entryBarIndex := bar_index
            trailingStop := trailingBase
    else
        if not na(trailingBase)
            if close < trailingStop
                sellSignal := true
                inPosition := false
                entryBarIndex := na
                trailingStop := na
            else
                trailingStop := math.max(trailingStop, trailingBase)

if buySignal
    strategy.entry("BUY", strategy.long)

if sellSignal
    strategy.close("BUY", comment="atr_trailing_exit")

plot(inPosition ? trailingStop : na, "Trailing Stop", color=color.orange, linewidth=2, style=plot.style_linebr)
plot(redCount, "Red Count", color=color.red, display=display.data_window)
plot(customAtr, "Custom ATR", color=color.blue, display=display.data_window)

plotshape(showSignals and buySignal, title="BUY", style=shape.triangleup, location=location.belowbar, color=color.lime, size=size.small, text="BUY")
plotshape(showSignals and sellSignal, title="SELL", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, text="SELL")

alertcondition(buySignal, "Strategy1 BUY", "Strategy1 live current BUY")
alertcondition(sellSignal, "Strategy1 SELL", "Strategy1 live current SELL")
